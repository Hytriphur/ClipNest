{
  "name": "clipnest",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -k -n server,web -c cyan,magenta \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "build": "npm run build -ws",
    "test": "npm run test -ws",
    "lint": "npm run lint -ws",
    "format": "prettier -w ."
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "prettier": "^3.6.2"
  }
}
